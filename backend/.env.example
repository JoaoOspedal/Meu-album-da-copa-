# Copie para `.env` e ajuste os valores.

# Banco de dados (padrão: SQLite local)
DATABASE_URL=sqlite:///./album_copa_2026.db

# Segurança JWT — GERE UMA CHAVE FORTE EM PRODUÇÃO
# ex.: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=troque-esta-chave-secreta-em-producao-2026
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS (separe por vírgula se restringir; o padrão é liberar tudo)
# CORS_ORIGINS=["https://meuapp.com"]
